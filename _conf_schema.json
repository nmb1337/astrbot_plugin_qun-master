{
  "enable_welcome": {
    "description": "启用入群欢迎",
    "type": "bool",
    "default": true,
    "hint": "关闭后将不会发送任何入群欢迎消息"
  },
  "welcome_group_whitelist": {
    "description": "入群欢迎群号白名单",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "仅在此白名单中的群发送欢迎消息"
  },
  "welcome_template": {
    "description": "欢迎语模板",
    "type": "string",
    "default": "欢迎新成员 {user_id} 加入本群，祝你聊天愉快。",
    "hint": "可使用占位符: {user_id} {group_id} {time}"
  },
  "welcome_image": {
    "description": "入群通知图片(URL或本地路径)",
    "type": "string",
    "default": "",
    "hint": "可留空；填写后会与欢迎文字一起发送"
  },
  "enable_leave_notice": {
    "description": "启用退群通知",
    "type": "bool",
    "default": true,
    "hint": "关闭后将不会发送退群通知"
  },
  "leave_template": {
    "description": "退群通知模板",
    "type": "string",
    "default": "成员 {user_id} 已离开本群。",
    "hint": "可使用占位符: {user_id} {group_id} {operator_id} {sub_type} {time}"
  },
  "leave_image": {
    "description": "退群通知图片(URL或本地路径)",
    "type": "string",
    "default": "",
    "hint": "可留空；填写后会与退群文字一起发送"
  },
  "enable_schedule": {
    "description": "启用定时消息",
    "type": "bool",
    "default": false,
    "hint": "关闭后不会执行定时推送"
  },
  "schedule_group_whitelist": {
    "description": "定时消息群号白名单",
    "type": "list",
    "items": {
      "type": "string"
    },
    "default": [],
    "hint": "仅向这些群发送定时消息"
  },
  "schedule_daily_time": {
    "description": "每日发送时间(HH:MM)",
    "type": "string",
    "default": "09:00",
    "hint": "24 小时制，例如 09:00 或 21:30"
  },
  "schedule_message": {
    "description": "定时发送内容",
    "type": "text",
    "default": "群通知：请文明发言，遵守群规。"
  }
}
